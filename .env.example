# Atlas Inbox — copy to .env for local dev. NEVER commit real secrets.

# --- OpenAI ---
OPENAI_API_KEY=sk-...
ATLAS_CHAT_MODEL=gpt-4o
ATLAS_EMBEDDING_MODEL=text-embedding-3-small
ATLAS_EMBEDDING_DIM=1536

# --- Database (Render Postgres + pgvector) ---
DATABASE_URL=postgresql://localhost:5432/atlas

# --- Google OAuth (sandbox account; web client) ---
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=http://localhost:8000/oauth/callback

# --- Token encryption ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENC_KEY=

# --- Langfuse (optional; tracing is a no-op if blank) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- App ---
ATLAS_DEFAULT_USER_ID=me
ATLAS_WORK_HOURS_START=9
ATLAS_WORK_HOURS_END=18
# IANA timezone for date reasoning + scheduling (e.g. Asia/Kolkata, America/New_York).
# "3pm" and "tomorrow" are interpreted in this zone. Defaults to UTC.
ATLAS_TIMEZONE=UTC
ATLAS_API_BASE=http://localhost:8000

# --- OAuth scope relaxation (set when requesting multiple Google scopes) ---
OAUTHLIB_RELAX_TOKEN_SCOPE=1
